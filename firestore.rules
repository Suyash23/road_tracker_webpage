rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write access to the "trips" collection
    match /trips/{document=**} {
      allow read, write: if true;
    }
    
    // Also allow access to the "inferred_lanes" collection
    match /inferred_lanes/{document=**} {
      allow read, write: if true;
    }
  }
}
